# PostgreSQL Configuration
POSTGRES_USER=secos_user
POSTGRES_PASSWORD=secos_secure_password_123
POSTGRES_DB=ai_secos_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j Configuration
NEO4J_AUTH=neo4j/neo4j_secure_password_123
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_DEBUG=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
SECRET_KEY=your-secret-key-change-in-production-123456789

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI-SecOS

# Application Configuration
APP_NAME=AI-SecOS
APP_VERSION=0.1.0
ENVIRONMENT=development
